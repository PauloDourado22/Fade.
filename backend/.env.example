PORT=4100
FRONTEND_URL=http://localhost:3100
CORS_ORIGIN=http://localhost:3100

# SQLite file path (created automatically on first run)
DATABASE_PATH=./data/barbershop.db

# Generate a strong random value for real use — this is just a dev placeholder.
# e.g. `openssl rand -hex 32`
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=8h

# Stripe TEST MODE keys only. Never put live secret keys in a repo or a
# portfolio demo — this project is scoped to test mode on purpose.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Minutes a pending (unpaid) booking holds its slot before it's released back
# to availability. Prevents someone abandoning checkout from blocking the slot
# forever, and short enough to limit "hold griefing" (someone repeatedly
# starting checkouts they never intend to pay, to lock out real customers).
HOLD_DURATION_MINUTES=10

# Set to false to skip Stripe checkout entirely and confirm every new booking
# immediately - lets you test availability, double-booking prevention, the
# dashboard, and reschedule/cancel without configuring real Stripe test keys.
# Double-booking protection still applies either way. Leave at true (or
# unset) once you're testing the real payment flow again.
DEPOSIT_ENABLED=true
